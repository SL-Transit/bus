{
  "rules": {
    "data": {
      "catalog": {
        ".read": true,
        ".write": "auth != null"
      },
      "fleet": {
        ".read": "auth != null && auth.token.role === 'admin'",
        ".write": "auth != null && auth.token.role === 'admin'",
        "vehicles": {
          "$vehicleId": {
            "password": {
              ".read": false
            }
          }
        }
      },
      "finance": {
        ".read": "auth != null",
        ".write": false
      },
      "settings": {
        ".read": true,
        ".write": "auth != null"
      }
    },
    "operations": {
      "bookings": {
        ".read": "auth != null",
        ".write": false,
        ".indexOn": ["date", "originKey", "destKey", "status"],
        "$bookingId": {
          ".write": "auth != null"
        }
      },
      "passengers": {
        ".read": "auth != null",
        ".write": false,
        "$passengerId": {
          ".write": false
        }
      },
      "liveVehicles": {
        ".read": true,
        "$vehicleId": {
          ".write": "auth != null && (auth.token.role === 'admin' || auth.token.vehicleId === $vehicleId)"
        }
      },
      "ticketLocations": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "driverLogs": {
        ".read": "auth != null && auth.token.role === 'admin'",
        ".write": "auth != null && (auth.token.role === 'driver' || auth.token.role === 'admin')"
      },
      "sosAlerts": {
        ".read": "auth != null && auth.token.role === 'admin'",
        ".write": "auth != null && (auth.token.role === 'driver' || auth.token.role === 'admin')"
      }
    },
    "admin": {
      ".read": "auth != null && auth.token.role === 'admin'",
      ".write": "auth != null && auth.token.role === 'admin'"
    },
    "meta": {
      ".read": true,
      ".write": false
    }
  }
}