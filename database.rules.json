{
  "rules": {
    "data": {
      "catalog": {
        ".read": true,
        ".write": "auth != null"
      },
      "fleet": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "finance": {
        ".read": "auth != null",
        ".write": false
      },
      "settings": {
        ".read": true,
        ".write": "auth != null"
      }
    },
    "operations": {
      "bookings": {
        ".read": "auth != null",
        ".write": false,
        ".indexOn": ["date", "originKey", "destKey", "status"],
        "$bookingId": {
          ".write": "auth != null"
        }
      },
      "passengers": {
        ".read": "auth != null",
        ".write": false,
        "$passengerId": {
          ".write": false
        }
      },
      "liveVehicles": {
        ".read": true,
        "$vehicleId": {
          ".write": "auth != null"
        }
      },
      "ticketLocations": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "driverLogs": {
        ".read": "auth != null",
        ".write": "auth != null"
      },
      "sosAlerts": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "publishedSchedule": {
      ".read": true,
      ".write": "auth != null"
    },
    "admin": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "meta": {
      ".read": true,
      ".write": false
    }
  }
}
